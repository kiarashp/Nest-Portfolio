# ==========================================
# Database
# ==========================================

DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_NAME=my_database

# TypeORM
DB_SYNC=false
DB_AUTO_LOAD_ENTITIES=true

# ==========================================
# Application
# ==========================================

APP_PORT=3000
API_VERSION=v1
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173


# ==========================================
# JWT
# ==========================================

JWT_SECRET=your_super_secret_jwt_key

JWT_TOKEN_AUDIENCE=http://localhost:3000
JWT_TOKEN_ISSUER=http://localhost:3000

JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400

# ==========================================
# Seed
# ==========================================

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@1234!

# Used by `pnpm run seed:dev` (editor/author/user accounts) — same pattern as
# SEED_ADMIN_EMAIL/PASSWORD above. Emails fall back to the defaults shown
# below if unset; the *_PASSWORD vars are required.
SEED_EDITOR_EMAIL=editor@example.com
SEED_EDITOR_PASSWORD=Editor@1234!
SEED_AUTHOR_EMAIL=author@example.com
SEED_AUTHOR_PASSWORD=Author@1234!
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=User@1234!

# ==========================================
# Google OAuth
# ==========================================

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==========================================
# Cloudinary
# ==========================================

CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==========================================
# Mail (SMTP)
# Use Mailtrap sandbox for development: https://mailtrap.io
# ==========================================

MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_SECURE=false
MAIL_USER=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM="No Reply <noreply@example.com>"