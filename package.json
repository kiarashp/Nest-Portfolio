{
  "name": "intro",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "prestart:prod": "node node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "start:prod": "node dist/main",
    "prestart:prod:local": "cross-env NODE_ENV=production node node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "start:prod:local": "cross-env NODE_ENV=production node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json",
    "test:e2e:fail": "cross-env NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --config ./test/jest-e2e.json --onlyFailures --verbose",
    "doc": "pnpm compodoc -p tsconfig.json -s --port 3001 --watch -d ./documentation",
    "seed:admin": "ts-node -r tsconfig-paths/register src/database/seeds/admin.seed.ts",
    "seed:dev": "ts-node -r tsconfig-paths/register src/database/seeds/dev-data.seed.ts",
    "typeorm": "cross-env NODE_ENV=development ts-node -P tsconfig.typeorm.json -r tsconfig-paths/register node_modules/typeorm/cli.js",
    "migrate:run": "pnpm run typeorm migration:run -d src/database/data-source.ts",
    "migrate:revert": "pnpm run typeorm migration:revert -d src/database/data-source.ts",
    "generate:schema": "cross-env NODE_ENV=development ts-node -r tsconfig-paths/register src/generate-schema.ts",
    "generate:types": "pnpm run generate:schema && openapi-typescript openapi.json -o openapi-types.ts"
  },
  "dependencies": {
    "@compodoc/compodoc": "^1.2.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "0.15.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "ejs": "^6.0.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "joi": "^18.2.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./",
    "modulePaths": [
      "<rootDir>"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}