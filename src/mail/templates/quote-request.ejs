<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Quote Request</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f4f4f4;
        font-family: Arial, sans-serif;
      }
      .wrapper {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }
      .header {
        background-color: #1a1a2e;
        padding: 32px 40px;
        text-align: center;
      }
      .header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 24px;
        letter-spacing: 1px;
      }
      .body {
        padding: 40px;
        color: #333333;
      }
      .body p {
        font-size: 16px;
        line-height: 1.6;
        margin: 0 0 16px;
      }
      .field-label {
        font-size: 12px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #888888;
        margin: 0 0 4px;
      }
      .field-value {
        font-size: 16px;
        line-height: 1.6;
        color: #333333;
        margin: 0 0 24px;
        padding: 12px 16px;
        background-color: #f9f9f9;
        border-left: 3px solid #1a1a2e;
        border-radius: 2px;
      }
      .field-value ul {
        margin: 0;
        padding-left: 20px;
      }
      .footer {
        background-color: #f4f4f4;
        padding: 20px 40px;
        text-align: center;
        font-size: 13px;
        color: #888888;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="header">
        <h1>New quote request</h1>
      </div>
      <div class="body">
        <p>A registered user requested a quote for a configured product.</p>

        <p class="field-label">From</p>
        <p class="field-value"><%= userFirstName %> &lt;<%= userEmail %>&gt;</p>

        <p class="field-label">Product</p>
        <p class="field-value"><%= productName %></p>

        <p class="field-label">Code</p>
        <p class="field-value"><%= code %></p>

        <p class="field-label">Summary</p>
        <div class="field-value">
          <ul>
            <% summary.forEach(function(line) { %>
            <li><%= line %></li>
            <% }) %>
          </ul>
        </div>
      </div>
      <div class="footer">
        <p>Reply directly to this email to respond to <%= userFirstName %>.</p>
      </div>
    </div>
  </body>
</html>
